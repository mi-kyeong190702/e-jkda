<?xml version="1.0" encoding="UTF-8"?>
<Context>
  <!-- JNDI DataSource 설정 (jdbc/dataSource1) -->
  <Resource
      name="jdbc/dataSource1"
      auth="Container"
      type="javax.sql.DataSource"
      
      driverClassName="com.microsoft.sqlserver.jdbc.SQLServerDriver"
      url="jdbc:sqlserver://127.0.0.1:1433;databaseName=test;encrypt=false;trustServerCertificate=true"
      username="app_login"
      password="1234"
      
      maxTotal="30"
      maxIdle="10"
      maxWaitMillis="10000"
      validationQuery="SELECT 1"
      testOnBorrow="true"
      removeAbandonedOnBorrow="true"
      removeAbandonedTimeout="60"
      logAbandoned="true" />
</Context>
